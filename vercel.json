{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "edynburg-pwa.vercel.app"
        }
      ],
      "destination": "https://edynburg.dryla.pl/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "edynburg-atlas.vercel.app"
        }
      ],
      "destination": "https://edynburg.dryla.pl/:path*",
      "permanent": true
    }
  ]
}
